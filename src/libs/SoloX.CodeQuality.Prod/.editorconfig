
[*.csproj]

#### Core EditorConfig Options ####

# Encoding
charset = utf-8-bom

# Indentation and spacing
indent_size = 2
indent_style = space
tab_width = 2

# New line preferences
end_of_line = crlf
insert_final_newline = false



